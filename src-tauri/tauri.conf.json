{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SaladVault",
  "version": "0.1.1",
  "identifier": "com.saladvault.app",
  "build": {
    "beforeDevCommand": "trunk serve --port 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "trunk build --release",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SaladVault - Gestionnaire de Mots de Passe",
        "width": 960,
        "height": 700,
        "minWidth": 600,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYyMURBNDc5OTE4OEQ3RUYKUldUdjE0aVJlYVFkOHVmR0VYbXJpSHliSDhsUlRyUk5PeDhrb1BCcHRERlZGckVISFNQaExQaSsK",
      "endpoints": [
        "https://github.com/salad-vault/tauri-app/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
